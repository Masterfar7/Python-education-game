  dialogueLines:
  - speaker: 1
    text: "\u0421\u043C\u043E\u0442\u0440\u0438. \u0422\u0432\u043E\u044F \u0441\u0438\u043B\u0430
      \u2014 \u0432 \u0443\u043C\u0435\u043D\u0438\u0438 \u0434\u0430\u0432\u0430\u0442\u044C
      \u0438\u043C\u0435\u043D\u0430 \u0438 \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u0442\u044C
      \u0438\u0445."
    startTaskAfterLine: 0
    showTaskObjectUIAfterText: 0
    taskObjectUI: {fileID: 0}
