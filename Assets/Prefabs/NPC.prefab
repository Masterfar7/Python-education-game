    leverToActivate: {fileID: 0}
    moveSpeedOverride: -1
    playerMoveSpeed: -1
    guideMoveSpeed: -1
  - speaker: 1
    text: "\u0421\u043E\u0437\u0434\u0430\u0439 \u0432 \u0441\u0432\u043E\u0451\u043C
      \u0440\u0430\u0437\u0443\u043C\u0435 (\u0438\u043B\u0438 \u0432 \u043A\u043E\u043D\u0441\u043E\u043B\u0438,
      \u0447\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u043B\u0430\u0441\u044C \u043F\u0435\u0440\u0435\u0434
      \u0442\u043E\u0431\u043E\u0439) \xAB\u043A\u043E\u0440\u043E\u0431\u043A\u0443\xBB-\u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u0443\u044E
      \u0434\u043B\u044F \u0438\u043C\u0435\u043D\u0438. \u041D\u0430\u0437\u043E\u0432\u0438
      \u0435\u0451 spirit_name. "
    startTaskAfterLine: 0
    showTaskObjectUIAfterText: 0
    taskObjectUI: {fileID: 0}
    showChapterCompleteUIAfterText: 0
    chapterCompleteUI: {fileID: 0}
    triggerStatueFlash: 0
