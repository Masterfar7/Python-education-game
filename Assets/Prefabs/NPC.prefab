  - speaker: 1
    text: "\u0410 \u0437\u0430\u0442\u0435\u043C \u043D\u0430\u043F\u043E\u043B\u043D\u0438
      \u0435\u0451 \u0442\u0435\u043C, \u0447\u0442\u043E \u0441\u043A\u0430\u0436\u0435\u0442
      \u0434\u0443\u0445, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
      \u0437\u0430\u043A\u043B\u0438\u043D\u0430\u043D\u0438\u0435 \u0432\u044B\u0437\u043E\u0432\u0430
      input()."
