      \u043A\u0432\u0435\u0441\u0442\u0430! \u042F \u0440\u0435\u0430\u043B\u044C\u043D\u043E
      \u043F\u0438\u0441\u0430\u043B \u0443\u0441\u043B\u043E\u0432\u0438\u044F \u0438
      \u0432\u044B\u0431\u0438\u0440\u0430\u043B \u0434\u0432\u0435\u0440\u0438!
      \u0415\u0441\u043B\u0438 \u0442\u0430\u043A \u0434\u0430\u043B\u044C\u0448\u0435
      \u043F\u043E\u0439\u0434\u0451\u0442, \u044F, \u043C\u043E\u0436\u0435\u0442,
