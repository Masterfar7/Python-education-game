      \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043E: \xAB\u042F \u0432\u0435\u0434\u0443
      \u043A \u0432\u044B\u0445\u043E\u0434\u0443\xBB. \u041D\u0430 \u043F\u0440\u0430\u0432\u043E\u0439:
      \xAB\u041B\u0435\u0432\u0430\u044F \u0434\u0432\u0435\u0440\u044C \u0432\u0435\u0434\u0451\u0442
      \u0432 \u043B\u043E\u0432\u0443\u0448\u043A\u0443\xBB. \u0418\u0437\u0432\u0435\u0441\u0442\u043D\u043E,
      \u0447\u0442\u043E \u043E\u0434\u043D\u0430 \u0438\u0437 \u043D\u0438\u0445
      \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u043F\u0440\u0430\u0432\u0434\u0443,
      \u0430 \u0434\u0440\u0443\u0433\u0430\u044F \u043B\u0436\u0451\u0442. \u0422\u0432\u043E\u044F
      \u0437\u0430\u0434\u0430\u0447\u0430 \u2014 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
      \u0437\u0430\u043A\u043B\u0438\u043D\u0430\u043D\u0438\u0435 \u0432\u044B\u0431\u043E\u0440\u0430
      if, \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0442\u044C \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u0443\u044E
      \u0434\u0432\u0435\u0440\u044C \u0438 \u043E\u0442\u043A\u0440\u044B\u0442\u044C
      \u0435\u0451."
