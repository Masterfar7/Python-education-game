    playerMoveSpeed: -1
    guideMoveSpeed: -1
  - speaker: 0
    text: "(\u0432\u043E\u0440\u0447\u0438\u0442, \u043D\u043E \u0437\u0430\u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043D\u043D\u043E
      \u0441\u043C\u043E\u0442\u0440\u0438\u0442 \u043D\u0430 \u0441\u0442\u0430\u0442\u0443\u044E)
      \u041B\u0430\u0434\u043D\u043E, \u0443\u0433\u043E\u0432\u043E\u0440\u0438\u043B.
      \u041F\u043E\u0438\u0433\u0440\u0430\u0435\u043C \u0432 \"\u041A\u0412\u041D\"
      \u0441 \u043A\u0430\u043C\u0435\u043D\u043D\u044B\u043C\u0438 \u0431\u043E\u043B\u0432\u0430\u043D\u0447\u0438\u043A\u0430\u043C\u0438."
    startTaskAfterLine: 0
    showTaskObjectUIAfterText: 0
