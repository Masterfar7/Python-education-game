    playerMoveSpeed: -1
    guideMoveSpeed: -1
  - speaker: 0
    text: "(\u043E\u0442\u0441\u043A\u0430\u043A\u0438\u0432\u0430\u0435\u0442) \u041D\u0438\u0444\u0438\u0433\u0430
      \u0441\u0435\u0431\u0435! \u0420\u0430\u0431\u043E\u0442\u0430\u0435\u0442!
      \u0414\u0435\u0434, \u044D\u0442\u043E... \u044D\u0442\u043E \u043A\u0440\u0443\u0442\u043E!"
    startTaskAfterLine: 0
    showTaskObjectUIAfterText: 0
    taskObjectUI: {fileID: 0}
