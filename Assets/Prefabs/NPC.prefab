  - speaker: 1
    text: "\u0422\u044B \u043D\u0430\u0443\u0447\u0438\u043B\u0441\u044F \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
      \u0441\u0438\u043B\u0443 \u0432\u044B\u0431\u043E\u0440\u0430 \u2014 \u0443\u0441\u043B\u043E\u0432\u043D\u044B\u0435
      \u043E\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u044B. \u0422\u0435\u043F\u0435\u0440\u044C
      \u0442\u044B \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u0448\u044C, \u0447\u0442\u043E
      \u043A\u043E\u0434 \u043C\u043E\u0436\u0435\u0442 \u0441\u0430\u043C \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0442\u044C
      \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u043D\u0430 \u043E\u0441\u043D\u043E\u0432\u0435
      \u0434\u0430\u043D\u043D\u044B\u0445. \u042D\u0442\u043E \u0432\u0430\u0436\u043D\u044B\u0439
      \u0448\u0430\u0433 \u043D\u0430 \u0442\u0432\u043E\u0451\u043C \u043F\u0443\u0442\u0438."
