  - speaker: 1
    text: "\u0417\u0430\u0434\u0430\u043D\u0438\u0435 1.1: \u0418\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439
      \u043A\u043E\u043C\u0430\u043D\u0434\u0443 input() \u0438 \u0441\u043E\u0445\u0440\u0430\u043D\u0438
      \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442 \u0432 \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u0443\u044E."
