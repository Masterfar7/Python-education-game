  - speaker: 0
    text: "(\u0447\u0435\u0448\u0435\u0442 \u0437\u0430\u0442\u044B\u043B\u043E\u043A)
      \u0422\u0430\u043A, \u0437\u043D\u0430\u0447\u0438\u0442, \u043E\u0434\u043D\u0430
      \u043F\u0440\u0430\u0432\u0434\u0430, \u043E\u0434\u043D\u0430 \u043B\u043E\u0436\u044C.
      \u0415\u0441\u043B\u0438 \u043B\u0435\u0432\u0430\u044F \u043F\u0440\u0430\u0432\u0430,
      \u0442\u043E \u043E\u043D\u0430 \u0432\u044B\u0445\u043E\u0434, \u0438 \u043F\u0440\u0430\u0432\u0430\u044F
      \u0442\u043E\u0433\u0434\u0430 \u0432\u0440\u0451\u0442, \u0447\u0442\u043E
      \u043B\u0435\u0432\u0430\u044F \u2014 \u043B\u043E\u0432\u0443\u0448\u043A\u0430.
      \u0421\u0445\u043E\u0434\u0438\u0442\u0441\u044F. \u0415\u0441\u043B\u0438
      \u043B\u0435\u0432\u0430\u044F \u0432\u0440\u0451\u0442, \u0442\u043E \u043E\u043D\u0430
      \u043D\u0435 \u0432\u044B\u0445\u043E\u0434, \u0430 \u043F\u0440\u0430\u0432\u0430\u044F
      \u0442\u043E\u0433\u0434\u0430 \u043F\u0440\u0430\u0432\u0430 \u2014 \u0437\u043D\u0430\u0447\u0438\u0442,
      \u043B\u0435\u0432\u0430\u044F \u2014 \u043B\u043E\u0432\u0443\u0448\u043A\u0430,
      \u0438 \u043D\u0430\u0434\u043E \u0438\u0434\u0442\u0438 \u043D\u0430\u043F\u0440\u0430\u0432\u043E.
      \u041C\u043D\u0435 \u043D\u0443\u0436\u043D\u043E \u043F\u0440\u043E\u0441\u0442\u043E
      \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C, \u043F\u0440\u0430\u0432\u0430
      \u043B\u0438 \u043B\u0435\u0432\u0430\u044F \u0434\u0432\u0435\u0440\u044C.
