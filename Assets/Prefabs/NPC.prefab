  - speaker: 1
    text: "\u041D\u0435\u0442. \u0427\u0442\u043E\u0431\u044B \u043E\u043D\u0438
      \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0438\u043B\u0438 \u0443\u0441\u0438\u043B\u0438\u044F,
      \u043D\u0443\u0436\u043D\u043E \u0440\u0430\u0441\u0441\u0447\u0438\u0442\u0430\u0442\u044C
      \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0438\u0440\u0443\u044E\u0449\u0443\u044E
      \u0441\u0438\u043B\u0443 \u0443\u0434\u0430\u0440\u0430. \u041F\u0435\u0440\u0435\u043C\u043D\u043E\u0436\u044C
      \u0438\u0445. \u0421\u043E\u0437\u0434\u0430\u0439 \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u0443\u044E
      strike_power \u0438 \u0432\u044B\u0432\u0435\u0434\u0438 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442."
