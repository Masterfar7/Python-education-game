  - speaker: 1
    text: "\u0410 \u0442\u0435\u043F\u0435\u0440\u044C \u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u044C.
      \u0421\u043E\u0440\u043D\u044F\u043A\u0438 \u043B\u0435\u0437\u0443\u0442,
      \u043F\u043E\u043A\u0430 \u0443 \u0442\u0435\u0431\u044F \u0435\u0441\u0442\u044C
      \u043C\u0430\u043D\u0430. \u041D\u0430\u0447\u0430\u043B\u044C\u043D\u044B\u0439
      \u0437\u0430\u043F\u0430\u0441 \u2014 100. \u041A\u0430\u0436\u0434\u044B\u0439
      \u0443\u0434\u0430\u0440 \u043E\u0442\u043D\u0438\u043C\u0430\u0435\u0442 15
      \u043C\u0430\u043D\u044B \u0438 \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0430\u0435\u0442
      \u043E\u0434\u0438\u043D \u0441\u043E\u0440\u043D\u044F\u043A."
