      objectReference: {fileID: 0}
    - target: {fileID: 8861933865349509865, guid: a359258f753d7d84a9406f8bcaa00956, type: 3}
      propertyPath: tasks.Array.data[0].referenceCode
      value: "for i in range(5):\r\n    print(\"\u0426\u0432\u0435\u0442\u043E\u043A,
        \u0440\u0430\u0441\u0442\u0438!\")\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 8861933865349509865, guid: a359258f753d7d84a9406f8bcaa00956, type: 3}
      propertyPath: tasks.Array.data[1].referenceCode
      value: "crystals = [\"red\", \"blue\", \"green\", \"yellow\"]\r\nfor crystal
        in crystals:\r\n    print(\"\u0417\u0430\u0440\u044F\u0436\u0430\u044E\",
        crystal, \"\u043A\u0440\u0438\u0441\u0442\u0430\u043B\u043B\")\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 8861933865349509865, guid: a359258f753d7d84a9406f8bcaa00956, type: 3}
      propertyPath: tasks.Array.data[2].referenceCode
      value: "mana = 100\r\nwhile mana > 0:\r\n    mana = mana - 15\r\n    print(\"\u0427\u0438\u0442\u0430\u0435\u0442
        \u0437\u0430\u043A\u043B\u0438\u043D\u0430\u043D\u0438\u0435. \u041E\u0441\u0442\u0430\u043B\u043E\u0441\u044C
        \u043C\u0430\u043D\u044B:\", mana)\r\nprint(\"\u041C\u0430\u043D\u0430 \u043A\u043E\u043D\u0447\u0438\u043B\u0430\u0441\u044C.
        \u0421\u043E\u0440\u043D\u044F\u043A\u0438 \u043E\u0442\u0441\u0442\u0443\u043F\u0438\u043B\u0438.\")\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 8861933865349509865, guid: a359258f753d7d84a9406f8bcaa00956, type: 3}
      propertyPath: tasks.Array.data[1].expectedString
      value: 
      objectReference: {fileID: 0}
    - target: {fileID: 8861933865349509865, guid: a359258f753d7d84a9406f8bcaa00956, type: 3}
      propertyPath: tasks.Array.data[2].expectedNumber
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 8861933865349509865, guid: a359258f753d7d84a9406f8bcaa00956, type: 3}
      propertyPath: tasks.Array.data[0].taskDescription
      value: "\u0412\u043E\u0442 \u0441\u043A\u0435\u043B\u0435\u0442. \u0417\u0430\u043F\u043E\u043B\u043D\u0438
        \u043F\u0440\u043E\u043F\u0443\u0441\u043A: for i in range(___):     print(\"\u0426\u0432\u0435\u0442\u043E\u043A,
        \u0440\u0430\u0441\u0442\u0438!\") \u041F\u043E\u0434\u0441\u043A\u0430\u0437\u043A\u0430:
        \u0427\u0438\u0441\u043B\u043E \u0432 range() \u2014 \u0441\u043A\u043E\u043B\u044C\u043A\u043E
        \u0440\u0430\u0437 \u043F\u043E\u0432\u0442\u043E\u0440\u0438\u0442\u044C. "
      objectReference: {fileID: 0}
    - target: {fileID: 8861933865349509865, guid: a359258f753d7d84a9406f8bcaa00956, type: 3}
      propertyPath: tasks.Array.data[1].taskDescription
      value: "\u0421\u043E\u0437\u0434\u0430\u0439 \u0441\u043F\u0438\u0441\u043E\u043A
        crystals = [\"red\", \"blue\", \"green\", \"yellow\"]. \u0410 \u0437\u0430\u0442\u0435\u043C
        \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439 \u0446\u0438\u043A\u043B
        for, \u0447\u0442\u043E\u0431\u044B \u043F\u0440\u043E\u0439\u0442\u0438\u0441\u044C
        \u043F\u043E \u043A\u0430\u0436\u0434\u043E\u043C\u0443."
      objectReference: {fileID: 0}
    - target: {fileID: 8861933865349509865, guid: a359258f753d7d84a9406f8bcaa00956, type: 3}
      propertyPath: tasks.Array.data[2].taskDescription
      value: "\u0421\u043A\u0435\u043B\u0435\u0442:  mana = 100 while mana > 0:    
        # \u043D\u0430\u043D\u0435\u0441\u0442\u0438 \u0443\u0434\u0430\u0440    
        mana = mana - 15     print(\"\u0421\u043E\u0440\u043D\u044F\u043A \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0435\u043D.
        \u041E\u0441\u0442\u0430\u043B\u043E\u0441\u044C \u043C\u0430\u043D\u044B:\",
        mana)  \u041F\u043E\u0441\u043B\u0435 \u0446\u0438\u043A\u043B\u0430 \u0432\u044B\u0432\u0435\u0434\u0438:
        \xAB\u041C\u0430\u043D\u0430 \u043A\u043E\u043D\u0447\u0438\u043B\u0430\u0441\u044C.
        \u0421\u043E\u0440\u043D\u044F\u043A\u0438 \u043E\u0442\u0441\u0442\u0443\u043F\u0438\u043B\u0438.\xBB "
      objectReference: {fileID: 0}
