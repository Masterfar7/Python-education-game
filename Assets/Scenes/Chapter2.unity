  dialogueLines:
  - speaker: 3
    text: "\u0412\u043E\u043B\u0448\u0435\u0431\u043D\u044B\u0439 \u0441\u0430\u0434.
      \u0412 \u0446\u0435\u043D\u0442\u0440\u0435 \u2014 \u0443\u0432\u044F\u0434\u0448\u0438\u0439
      \u0446\u0432\u0435\u0442\u043E\u043A, \u0447\u0435\u0442\u044B\u0440\u0435
      \u0442\u0443\u0441\u043A\u043B\u044B\u0445 \u043A\u0440\u0438\u0441\u0442\u0430\u043B\u043B\u0430
      \u043F\u043E \u043A\u0440\u0443\u0433\u0443, \u0437\u0435\u043C\u043B\u044F
      \u0432 \u0441\u043E\u0440\u043D\u044F\u043A\u0430\u0445.)\r\n"
