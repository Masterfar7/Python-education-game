  - speaker: 1
    text: "\u0421\u043A\u0435\u043B\u0435\u0442:  mana = 100 while mana > 0:    
      # \u043D\u0430\u043D\u0435\u0441\u0442\u0438 \u0443\u0434\u0430\u0440     mana
      = mana - 15     print(\"\u0421\u043E\u0440\u043D\u044F\u043A \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0435\u043D.
      \u041E\u0441\u0442\u0430\u043B\u043E\u0441\u044C \u043C\u0430\u043D\u044B:\",
      mana)  \u041F\u043E\u0441\u043B\u0435 \u0446\u0438\u043A\u043B\u0430 \u0432\u044B\u0432\u0435\u0434\u0438:
