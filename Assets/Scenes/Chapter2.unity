  - speaker: 1
    text: "\u0414\u043E\u0431\u0440\u043E \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u0442\u044C
      \u0432 \u0421\u0430\u0434 \u0412\u0435\u0447\u043D\u043E\u0433\u043E \u0426\u0432\u0435\u0442\u0435\u043D\u0438\u044F.
      \u0417\u0434\u0435\u0441\u044C \u0446\u0430\u0440\u044F\u0442 \u0446\u0438\u043A\u043B\u044B.
      \u0411\u0435\u0437 \u043D\u0438\u0445 \u0440\u0430\u0441\u0442\u0435\u043D\u0438\u044F
      \u043D\u0435 \u0440\u0430\u0441\u0442\u0443\u0442, \u043A\u0440\u0438\u0441\u0442\u0430\u043B\u043B\u044B
      \u043D\u0435 \u0433\u043E\u0440\u044F\u0442, \u0430 \u0441\u043E\u0440\u043D\u044F\u043A\u0438
      \u0437\u0430\u043F\u043E\u043B\u043E\u043D\u044F\u0442 \u0432\u0441\u0451."
    startTaskAfterLine: 0
    isManaChallenge: 0
